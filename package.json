{
  "name": "microsandbox-cloud",
  "version": "0.0.1",
  "private": true,
  "description": "Minimal Microsandbox control plane and signed proxy.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w apps/cloud-api",
    "build:sshd": "bash ./scripts/build-inject-sshd.sh",
    "build:gateway": "bash ./scripts/build-ssh-gateway.sh",
    "build:ssh": "npm run build:sshd && npm run build:gateway",
    "build:all": "npm run build && npm run build:ssh",
    "start": "npm run start -w apps/cloud-api",
    "start:dev": "npm run start:dev -w apps/cloud-api",
    "start:prod": "npm run start:prod -w apps/cloud-api",
    "test": "npm run test -w apps/cloud-api",
    "lint": "npm run lint -w apps/cloud-api",
    "format": "prettier --write \"apps/cloud-api/src/**/*.ts\" \"apps/cloud-api/test/**/*.ts\"",
    "package:release": "bash ./scripts/package-release.sh"
  },
  "license": "Apache-2.0"
}

# SSH Gateway configuration
# Copy this to /opt/microsandbox-cloud/deploy/ssh-gateway.env
# and fill in your API key (must match MICROSANDBOX_CLOUD_INTERNAL_API_TOKEN)

API_URL=http://localhost:3210
API_KEY=change-me
SSH_GATEWAY_PORT=2222
SSH_HOST_KEY=/opt/microsandbox-cloud/data/ssh/gateway_host_key

# Server
MICROSANDBOX_CLOUD_PORT=3210
MICROSANDBOX_CLOUD_HOST=0.0.0.0

# Database & storage
MICROSANDBOX_CLOUD_SQLITE_PATH=./data/microsandbox-cloud.sqlite
MICROSANDBOX_CLOUD_MANAGED_VOLUME_ROOT=./data/volumes

# Auth tokens
MICROSANDBOX_CLOUD_INTERNAL_API_TOKEN=change-me
MICROSANDBOX_CLOUD_PROXY_TOKEN_SECRET=change-me-too

# Connection / TTL
MICROSANDBOX_CLOUD_CONNECTION_TTL_SECONDS=600

# Proxy
MICROSANDBOX_CLOUD_PROXY_BASE_URL=http://localhost:3210

# Runtime host
MICROSANDBOX_CLOUD_RUNTIME_HOST_NAME=local
MICROSANDBOX_CLOUD_RUNTIME_HOST_BASE_URL=http://localhost:4213
MICROSANDBOX_CLOUD_RUNTIME_HOST_PUBLIC_BASE_URL=
# MICROSANDBOX_CLOUD_GUEST_GATEWAY_PORT=18789

# Naming
MICROSANDBOX_CLOUD_SANDBOX_NAME_PREFIX=runtime
MICROSANDBOX_CLOUD_VOLUME_NAME_PREFIX=vol

# Port range
MICROSANDBOX_CLOUD_PORT_RANGE_START=31000
MICROSANDBOX_CLOUD_PORT_RANGE_END=31999

# Default sandbox spec
MICROSANDBOX_CLOUD_DEFAULT_IMAGE=nginx:stable-alpine
MICROSANDBOX_CLOUD_DEFAULT_EXPOSED_PORT=8080
MICROSANDBOX_CLOUD_DEFAULT_VOLUME_MOUNT_PATH=/workspace
MICROSANDBOX_CLOUD_DEFAULT_CPU=1
MICROSANDBOX_CLOUD_DEFAULT_MEMORY_MIB=2048
MICROSANDBOX_CLOUD_DEFAULT_DISK_GIB=6

# Polling / healthcheck
MICROSANDBOX_CLOUD_HEALTHCHECK_TIMEOUT_MS=3000
MICROSANDBOX_CLOUD_RUNTIME_READY_TIMEOUT_MS=15000
MICROSANDBOX_CLOUD_RUNTIME_READY_POLL_INTERVAL_MS=1000
